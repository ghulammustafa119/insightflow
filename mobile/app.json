{
  "expo": {
    "name": "InsightFlow",
    "slug": "insightflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "insightflow",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.insightflow.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-document-picker",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e3c924c8-46f2-4ed7-92cc-c233637f8f8f"
      }
    }
  }
}
